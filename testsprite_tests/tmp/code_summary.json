  ],
  "features": [
    {
      "name": "Authentication",
      "description": "User authentication system with role-based access control (admin, accountant). Includes login, logout, registration, password reset, and email verification.",
      "files": [
        "app/Http/Controllers/Auth/AuthenticatedSessionController.php",
        "app/Http/Controllers/Auth/RegisteredUserController.php",
        "app/Http/Controllers/Auth/PasswordResetLinkController.php",
        "app/Http/Controllers/Auth/NewPasswordController.php",
        "app/Http/Controllers/Auth/VerifyEmailController.php",
        "routes/auth.php"
      ],
      "api_doc": {
        "openapi": "3.0.0",
        "paths": {
          "/login": {
            "get": {
              "summary": "Show login form",
              "tags": ["Authentication"]
            },
            "post": {
              "summary": "Authenticate user",
              "requestBody": {
                "required": true,
                "content": {
                  "application/x-www-form-urlencoded": {
                    "schema": {
                      "type": "object",
                      "properties": {
                        "email": {"type": "string", "format": "email"},
                        "password": {"type": "string"},
                        "remember": {"type": "boolean"}
                      },
                      "required": ["email", "password"]
                    }
                  }
                }
              },
              "responses": {
                "302": {"description": "Redirect to dashboard based on role"}
              }
            }
          },
          "/register": {
            "get": {"summary": "Show registration form"},
            "post": {
              "summary": "Register new user",
              "requestBody": {
                "content": {
                  "application/x-www-form-urlencoded": {
                    "schema": {
                      "type": "object",
                      "properties": {
                        "name": {"type": "string"},
                        "email": {"type": "string", "format": "email"},
                        "password": {"type": "string"},
                        "password_confirmation": {"type": "string"}
                      }
                    }
                  }
                }
              }
            }
          },
          "/logout": {
            "post": {"summary": "Logout user"}
          }
        }
      }
    },
    {
      "name": "Admin Dashboard",
      "description": "Main dashboard displaying sales statistics, risky zones, top performers (pharmacists, doctors, representatives), latest invoices, overdue invoices, and high discount pharmacists. Supports filtering by month and year. Includes line-specific dashboards.",
      "files": [
        "app/Http/Controllers/Admin/DashboardController.php",
        "resources/views/admin/dashboard.blade.php"
      ],
      "api_doc": {
        "openapi": "3.0.0",
        "paths": {
          "/admin": {
            "get": {
              "summary": "Display admin dashboard",
              "parameters": [
                {"name": "month", "in": "query", "schema": {"type": "integer"}},
                {"name": "year", "in": "query", "schema": {"type": "integer"}}
              ]
            }
          },
          "/admin/dashboard/line/{id}": {
            "get": {
              "summary": "Display line-specific dashboard",
              "parameters": [
                {"name": "id", "in": "path", "required": true, "schema": {"type": "integer", "enum": [1, 2]}},
                {"name": "month", "in": "query", "schema": {"type": "integer"}},
                {"name": "year", "in": "query", "schema": {"type": "integer"}}
              ]
            }
          }
        }
      }
    },
    {
      "name": "Drugs Management",
      "description": "CRUD operations for managing drugs. Each drug has name, price, and line (1 or 2). Includes sales history and statistics per drug.",
      "files": [
        "app/Http/Controllers/Admin/DrugController.php",
        "app/Models/Drug.php"
      ],
      "api_doc": {
        "openapi": "3.0.0",
        "paths": {
          "/admin/drugs": {
            "get": {"summary": "List all drugs"},
            "post": {
              "summary": "Create new drug",
              "requestBody": {
                "content": {
                  "application/x-www-form-urlencoded": {
                    "schema": {
                      "type": "object",
                      "properties": {
                        "name": {"type": "string"},
                        "price": {"type": "number"},
                        "line": {"type": "integer", "enum": [1, 2]}
                      },
                      "required": ["name", "price", "line"]
                    }
                  }
                }
              }
            }
          },
          "/admin/drugs/{id}": {
            "get": {"summary": "Show drug details with sales history"},
            "put": {"summary": "Update drug"},
            "delete": {"summary": "Delete drug"}
          }
        }
      }
    },
    {
      "name": "Invoices Management",
      "description": "Complete invoice management system. Create, edit, delete, view invoices. Supports filtering by date, center, zone, pharmacist, doctor, representative, status, line. Includes PDF generation, CSV export, warehouse stock deduction, doctor deal tracking, and payment status management.",
      "files": [
        "app/Http/Controllers/Admin/InvoiceController.php",
        "app/Models/Invoice.php",
        "app/Models/InvoiceDetail.php"
      ],
      "api_doc": {
        "openapi": "3.0.0",
        "paths": {
          "/admin/invoices": {
            "get": {
              "summary": "List invoices with filtering",
              "parameters": [
                {"name": "start_date", "in": "query"},
                {"name": "end_date", "in": "query"},
                {"name": "center_id", "in": "query"},
                {"name": "zone_id", "in": "query"},
                {"name": "pharmacist_id", "in": "query"},
                {"name": "doctor_id", "in": "query"},
                {"name": "representative_id", "in": "query"},
                {"name": "status", "in": "query"},
                {"name": "line", "in": "query"},
                {"name": "serial_number", "in": "query"}
              ]
            },
            "post": {
              "summary": "Create new invoice",
              "requestBody": {
                "content": {
                  "application/x-www-form-urlencoded": {
                    "schema": {
                      "type": "object",
                      "properties": {
                        "serial_number": {"type": "string"},
                        "invoice_date": {"type": "string", "format": "date"},
                        "line": {"type": "integer", "enum": [1, 2]},
                        "pharmacist_id": {"type": "integer"},
                        "doctor_id": {"type": "integer"},
                        "status": {"type": "integer", "enum": [1, 2, 3]},
                        "paid_amount": {"type": "number"},
                        "items": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "drug_id": {"type": "integer"},
                              "quantity": {"type": "number"},
                              "pharmacist_discount_percentage": {"type": "number"}
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "/admin/invoices/{id}": {
            "get": {"summary": "Show invoice details"},
            "put": {"summary": "Update invoice"},
            "delete": {"summary": "Delete invoice"}
          },
          "/admin/invoices/export": {
            "get": {"summary": "Export invoices to CSV"}
          },
          "/admin/invoices/{id}/pdf": {
            "get": {"summary": "Generate PDF for invoice"}
          }
        }
      }
    },
